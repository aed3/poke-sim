{
  "version": 8,
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "binaryDir": "build/${presetName}",
      "cacheVariables": {
        "POKESIM_ENABLE_TESTING": "OFF",
        "POKESIM_ENABLE_BENCHMARKING": "OFF",
        "POKESIM_ENTITY_VIEWER": "OFF",
        "POKESIM_USING_PRESET": "ON",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": {
          "type": "FILEPATH",
          "value": "bin"
        }
      }
    },
    {
      "name": "debug",
      "inherits": "default",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "default",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "POKESIM_OPTIMIZE_FOR_NATIVE": "ON"
      }
    },
    {
      "name": "test",
      "inherits": "default",
      "cacheVariables": {
        "POKESIM_ENABLE_TESTING": "ON"
      }
    },
    {
      "name": "benchmark",
      "hidden": true,
      "cacheVariables": {
        "POKESIM_ENABLE_BENCHMARKING": "ON"
      }
    },
    {
      "name": "entity-viewer",
      "cacheVariables": {
        "POKESIM_ENTITY_VIEWER": "ON"
      }
    },
    {
      "name": "test-debug",
      "inherits": [
        "entity-viewer",
        "test",
        "debug"
      ]
    },
    {
      "name": "test-release",
      "inherits": [
        "test",
        "release"
      ]
    },
    {
      "name": "benchmark-debug",
      "inherits": [
        "entity-viewer",
        "benchmark",
        "debug"
      ]
    },
    {
      "name": "benchmark-release",
      "inherits": [
        "benchmark",
        "release"
      ]
    },
    {
      "name": "benchmark-release-with-checks",
      "inherits": [
        "benchmark-release"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "POKESIM_ENABLE_TESTING": "ON",
        "POKESIM_OPTIMIZE_FOR_NATIVE": null
      }
    },
    {
      "name": "profile",
      "inherits": [
        "benchmark",
        "default"
      ],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "hidden": true,
      "jobs": 0
    },
    {
      "name": "test",
      "hidden": true,
      "inherits": "default",
      "targets": "PokeSimTests"
    },
    {
      "name": "benchmark",
      "hidden": true,
      "inherits": "default",
      "targets": "PokeSimBenchmarks"
    },
    {
      "name": "test-debug",
      "inherits": "test",
      "configurePreset": "test-debug"
    },
    {
      "name": "test-release",
      "inherits": "test",
      "configurePreset": "test-release"
    },
    {
      "name": "benchmark-debug",
      "inherits": "benchmark",
      "configurePreset": "benchmark-debug"
    },
    {
      "name": "benchmark-release",
      "inherits": "benchmark",
      "configurePreset": "benchmark-release"
    },
    {
      "name": "benchmark-release-with-checks",
      "inherits": "benchmark",
      "configurePreset": "benchmark-release-with-checks"
    },
    {
      "name": "profile",
      "inherits": "benchmark",
      "configurePreset": "profile"
    }
  ]
}
